# ShadeMap API key (required for 2.5D building shadows on the map)
# Get one at https://shademap.app/about/
VITE_SHADEMAP_API_KEY=

# Optional: Mapbox Streets instead of OpenFreeMap (3D buildings still use OpenFreeMap tiles)
VITE_MAPBOX_ACCESS_TOKEN=

# API proxy target (vite dev server proxies /api -> localhost:8000)
# VITE_API_URL=/api

VITE_DEFAULT_AOI=az-phoenix
