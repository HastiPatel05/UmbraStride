# Shade worker profile mode: synthetic or building-aware (Overpass + SunCalc, no API key)
SHADE_PROFILE_MODE=synthetic

# Optional: Mapbox buildings at zoom 15+ (Overpass fallback if empty)
MAPBOX_ACCESS_TOKEN=

# Data directory (graphs, shade cache)
DATA_DIR=./data

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Shade worker
SHADE_WORKER_URL=http://127.0.0.1:3001
SHADE_WORKER_CONCURRENCY=2

# Routing performance
ROUTING_DISK_CACHE=1
ROUTING_WARM_ON_STARTUP=1
ROUTING_WARM_HOURS=10,11,12,13,14
ROUTING_PATH_ENGINE=rustworkx
ROUTING_USE_ASTAR=1
ROUTING_CORRIDOR_SCALES=0.6,1.0,1.6,3.0

# Auto synthetic shade (no manual seed_demo_cache for each datetime)
AUTO_SHADE_SEED=1
SHADE_AUTO_SYNC_SEC=300

# Routing defaults
SUN_AVERSION_BETA=5.0
DEFAULT_AOI_ID=az-phoenix
SNAP_MAX_DIST_M=1200
# CPU parallelism (0 = use all cores; unset same as 0)
UMBRASTIDE_CPU_WORKERS=0
ROUTING_DIJKSTRA_WORKERS=0
ROUTING_BUILD_WORKERS=0
SHADE_SEED_WORKERS=0
PRECOMPUTE_WORKERS=0
BOOTSTRAP_WORKERS=0
