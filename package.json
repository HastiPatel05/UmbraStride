{
  "name": "umbrastride",
  "private": true,
  "version": "0.1.0",
  "description": "Shadow-oriented pedestrian navigation",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:web": "npm run dev -w @umbrastride/web",
    "dev:api": "cd services/api && uvicorn umbrastride_api.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:worker": "npm run dev -w @umbrastride/shade-worker",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up"
  },
  "engines": {
    "node": ">=20"
  }
}
