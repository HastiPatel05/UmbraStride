{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build -w @umbrastride/web",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{apps/**,services/**,packages/**,docs/**,scripts/**,data/**,tests/**,__tests__/**,**/*.test.py,**/test_*.py,.codegraph/**,.git/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
